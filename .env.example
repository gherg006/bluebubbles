# Example-only values. Never place real credentials in this file.
BLUEBUBBLES_ENVIRONMENT=development
BLUEBUBBLES_SERVER_HOST=127.0.0.1
BLUEBUBBLES_SERVER_PORT=8443
BLUEBUBBLES_DATABASE_URL=postgresql+asyncpg://bluebubbles:replace-me@127.0.0.1/bluebubbles
BLUEBUBBLES_REDIS_URL=redis://127.0.0.1:6379/0
# Load real secrets from protected files on the Debian server.
BLUEBUBBLES_TOKEN_SECRET_FILE=/etc/bluebubbles/secrets/token-secret
BLUEBUBBLES_DATABASE_URL_FILE=/etc/bluebubbles/secrets/database-url
BLUEBUBBLES_REDIS_URL_FILE=/etc/bluebubbles/secrets/redis-url

# Windows client settings use their own namespace and never read server secrets.
BLUEBUBBLES_CLIENT_SERVER_URL=https://192.168.0.210:8443
BLUEBUBBLES_CLIENT_WEBSOCKET_URL=wss://192.168.0.210:8443/ws
BLUEBUBBLES_CLIENT_TRUSTED_CA=C:\ProgramData\BlueBubbles\internal-ca.crt
